# 

class GD_minimizer(nn.Module):                              #Class
    def __init__(self, objective, x0=np.array([0.,0.])):    #Method to initialize object
        super().__init__()
        
        self.objective = objective                # passed in f from runtime
        self.x0 = np.array(x0)                    # passed in initial condition
        
        # make optimizeable via nn.Parameter
        self.u = nn.Parameter(torch.Tensor([x0]), requires_grad=True)
        
        return                                    # optimizable multi-dimension u vector to be split

    def forward(self):                                      #
        output = self.objective(self.u[0])
        return output
    #
    
    def train(self, nit=1001, lr=2, print_every=100):
        # set the optimizer and associated settings (gradient descent the simplest)
        # optimizer = torch.optim.SGD(self.parameters(), lr=lr)
        self.lr = lr
        self.history = np.zeros( (nit,2) )
        self.history[0,:] = self.u[0].detach().numpy()
        
        # temp_grad = []
        # next_func = []
        
        
        for k in range(1,nit):
            t=2
            func = self()    # really: self.forward() takes in u[0] (first layer of tensor; 2 element vector on this)
            func.backward()  # real deal Calculus positive grad calc for # of dimensions of u[0] doesn't output anything and grad now can be called   
            print("Gradient: ",self.u.grad)
            print("Current Function Scalar Output: ", func.item())
            temp_grad = self.u.grad
            next_u = self.u[0].detach() - ( t * temp_grad )
            print("Next U Vector: ", next_u)
            next_func = self.objective(next_u[0,:]).item()
            print("Next Function Scalar Output: ", next_func)
            
            while next_func > func.item():                          # ***
                t = t / 2
                temp_grad = self.u.grad
                next_u = self.u[0].detach() - ( t * temp_grad )
                next_func = self.objective(next_u[0,:]).item()
                print("Next Function Scalar: ", next_func)
                
            print("next_u shape:", next_u.shape)
            print(k)
            self.u = nn.Parameter(torch.Tensor(next_u), requires_grad=True)  # Update u parameter as new inital condition...may be clunky, maybe a better way??
            self.history[k,:] = self.u[0].detach().numpy()  #store the coords in matrix
                                        
            # print("Current x: ",self.u[0,0].item()) # x value of gradient
            # print("Current y: ",self.u[0,1].item()) # y value of gradient
            
            
            # if k%print_every==1:
            #     x = self.u.detach().numpy()[0]
            #     f_x = func.detach().numpy()
            #     print(f'iter: {k:2} : (x,y) = {x:6.3f},{x:6.3f} ')
        #
        return self.u
    #

