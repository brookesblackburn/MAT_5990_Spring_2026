    def _f(x,y): # scalar input version, useful for contour plot
        # IMPORTANT: for more complicated functions. use torch-based functions;
        # e.g. torch.sin(...) rather than np.sin(...).
        # ----- Three-Hump Camel
        return (x**2) - (x*y) + (y**2)
        
    def f(u):
        # vector input version;
        # useful for torch, scipy.integrate.solve_ivp, etc
        x,y = u
        return _f(x,y)
    
